# ─────────────────────────────────────────────────────────────
# Supabase
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Solo para uso en servidor (rutas API / server actions). NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Nova Lab

# ─────────────────────────────────────────────────────────────
# Integracion de facturacion (Wally) — por tenant se puede sobrescribir en BD
# ─────────────────────────────────────────────────────────────
WALLY_API_BASE_URL=https://api.wally.example
WALLY_API_KEY=your-wally-api-key
WALLY_ENABLED=false
# Secreto compartido para validar el webhook de estados de pago (POST /api/webhooks/wally)
WALLY_WEBHOOK_SECRET=your-webhook-secret

# ─────────────────────────────────────────────────────────────
# Entrega de resultados (email/SMS) — proveedor opcional
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=your-resend-key
RESULTS_PUBLIC_BASE_URL=http://localhost:3000/portal

# NubeFact (facturación electrónica SUNAT Perú) — PSE/OSE
# Ruta única + token de la cuenta (menú Integraciones → API).
# Sin credenciales, la emisión opera en modo simulación.
NUBEFACT_API_URL=""
NUBEFACT_TOKEN=""
